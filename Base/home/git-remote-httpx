}

http_body() {
    state=free
    for $(cat) {
        match $state {
            free {
                if test $it = "\r" {
                    state=dump
                }
            }
            dump {
                echo $it
            }
        }
    }
}

username=''
password=''
for $(cat) {
    dbg command is "'$it'"
    match $it {
        capabilities {
            echo connect
            echo
        }
        connect\ * as (service) {
            dbg connect to $service
            match $(ensure_user_pass $username $password) {
                *:* as (u p) {
                    username=$u
                    password=$p
                }
            }
            token=$(echo -n "$username:$password" | base64)
            dbg auth $username:$password basic $token
            # response=$(curl \
            #    -H "Authorization: Basic $token" \
            #    "$url/info/refs?service=$service")

            # hilight debug
            # echo -n $response | xxd >&2
            # hilight normal

            echo
            curl -d '@-' -v \
               -H "Authorization: Basic $token" \
               "$url/$service"

            echo
        }
        fetch\ *\ * as (sha1 name) {
            upload_pack $sha1 $name \
                | curl -v -d '@-' $url/git-upload-pack
        }
        list {
            curl "$url/info/refs?service=git-upload-pack" | parse_refspack
            echo
        }
        * {
            dbg "Unknown command $it"
            exit 0
        }
    }
}

